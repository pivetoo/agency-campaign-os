{
  "IdentityCatalog": {
    "BaseUrl": "https://auth.mainstay.com.br",
    "IdMApiKey": "e010925f-093c-4c70-bb50-e19279fa8962",
    "ApplicationId": "agency-campaign",
    "CacheTtl": "12:00:00",
    "NegativeCacheTtl": "00:01:00"
  },
  "Jwt": {
    "Issuer": "identity-management",
    "Audience": "agency-campaign"
  },
  "Apify": {
    "Token": "",
    "Platforms": [
      {
        "Match": "instagram",
        "ActorId": "apify~instagram-scraper",
        "UrlField": "directUrls",
        "UrlAsObject": false,
        "LikesField": "likesCount",
        "CommentsField": "commentsCount",
        "ViewsField": "videoViewCount",
        "SharesField": null
      },
      {
        "Match": "tiktok",
        "ActorId": "clockworks~tiktok-scraper",
        "UrlField": "postURLs",
        "UrlAsObject": false,
        "LikesField": "diggCount",
        "CommentsField": "commentCount",
        "ViewsField": "playCount",
        "SharesField": "shareCount"
      },
      {
        "Match": "youtube",
        "ActorId": "streamers~youtube-scraper",
        "UrlField": "startUrls",
        "UrlAsObject": true,
        "LikesField": "likes",
        "CommentsField": "commentsCount",
        "ViewsField": "viewCount",
        "SharesField": null
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "RunMigrations": true,
  "AllowedHosts": "*"
}